@using GuideFlow.Enums
@using GuideFlow.Models
@namespace GuideFlow.Components

@* Overlay is now rendered and animated entirely via JS (guideflow.module.js).
   This component exists only for Blazor lifecycle and event wiring. *@

@code {
    [Parameter] public bool Visible { get; set; }
    [Parameter] public double Opacity { get; set; } = 0.5;
    [Parameter] public string? Color { get; set; }
    [Parameter] public int ZIndex { get; set; } = 10000;
    [Parameter] public bool AnimateCutout { get; set; } = true;
    [Parameter] public int AnimationDuration { get; set; } = 300;
    [Parameter] public EventCallback OnClick { get; set; }
    [Parameter] public OverlayMode Mode { get; set; } = OverlayMode.Cutout;
    [Parameter] public HighlightShape Shape { get; set; } = HighlightShape.RoundedRect;
}
