@page "/docs/confirm-on-exit"
@using GuideFlow.Services
@using GuideFlow.Enums

<PageTitle>Confirm On Exit - GuideFlow</PageTitle>

<div class="docs-content">
    <h1 id="confirm-on-exit-title">Confirm On Exit</h1>
    <p class="docs-lead" id="confirm-on-exit-lead">Show a confirmation dialog when the user presses Escape or clicks the overlay to exit mid-tour. Prevents accidental dismissal of important onboarding flows and lets you run custom logic before the tour closes.</p>

    <button class="docs-demo__run" @onclick="StartTour" id="confirm-on-exit-run-btn">▶ Show me the example</button>

    <h2 id="usage">Usage <a class="docs-anchor" href="#usage">#</a></h2>

    <div id="confirm-on-exit-code">
        <CodeBlock Language="razor" Code="@(@"<GuideFlowTour @ref=""tour"" TourOptions=""options"">
    <GuideFlowStep Element=""#confirm-on-exit-title"" Title=""Step 1"" Order=""0""
                   Side=""Placement.Bottom"" Align=""PopoverAlign.Start"">
        <p>Try to close this tour.</p>
    </GuideFlowStep>
</GuideFlowTour>

@code {
    private GuideFlowTour? tour;
    private TourOptions options = new()
    {
        AllowClose = false, // Prevent closing without confirmation
    };

    private async Task StartTour() { if (tour != null) await tour.DriveAsync(); }

    // In the component logic:
    // private async Task<bool> OnBeforeDestroy() {
    //     return await JSRuntime.InvokeAsync<bool>(""confirm"", ""Are you sure?"");
    // }
}")" />
    </div>

</div>

<GuideFlowTour @ref="tour" TourOptions="options">
    <GuideFlowStep Element="#confirm-on-exit-title" Title="Step 1" Order="0"
                   Side="Placement.Bottom" Align="PopoverAlign.Start">
        <p>Try to close this tour.</p>
    </GuideFlowStep>
</GuideFlowTour>

@code {
    private GuideFlowTour? tour;

    private TourOptions options = new()
    {
        AllowClose = false,
    };

    private async Task StartTour()
    {
        if (tour != null) await tour.DriveAsync();
    }
}
