@code {
    // Default tour
    private GuideFlowTour? tour;
    private TourOptions defaultOpts = new()
    {
        ShowProgress = true,
    };

    // Animation type tours
    private GuideFlowTour? fadeTour, slideTour, bounceTour, noneTour;
    private TourOptions fadeOpts = new()
    {
        ShowButtons = new[] { ButtonType.Next, ButtonType.Previous, ButtonType.Close },
    };
    private TourOptions slideOpts = new()
    {
        ShowButtons = new[] { ButtonType.Next, ButtonType.Previous, ButtonType.Close },
    };
    private TourOptions bounceOpts = new()
    {
        ShowButtons = new[] { ButtonType.Next, ButtonType.Previous, ButtonType.Close },
    };
    private TourOptions noneOpts = new()
    {
        ShowButtons = new[] { ButtonType.Next, ButtonType.Previous, ButtonType.Close },
    };

    // Animate toggle tours
    private GuideFlowTour? animatedTour, notAnimatedTour;
    private TourOptions animatedOpts = new()
    {
        Animate = true,
        ShowButtons = new[] { ButtonType.Next, ButtonType.Previous, ButtonType.Close },
    };
    private TourOptions notAnimatedOpts = new()
    {
        Animate = false,
        ShowButtons = new[] { ButtonType.Next, ButtonType.Previous, ButtonType.Close },
    };

    // Duration tours
    private GuideFlowTour? fastTour, defaultDurationTour, slowTour;
    private TourOptions fastOpts = new()
    {
        AnimationDuration = 150,
        ShowButtons = new[] { ButtonType.Next, ButtonType.Previous, ButtonType.Close },
    };
    private TourOptions defaultDurationOpts = new()
    {
        AnimationDuration = 300,
        ShowButtons = new[] { ButtonType.Next, ButtonType.Previous, ButtonType.Close },
    };
    private TourOptions slowOpts = new()
    {
        AnimationDuration = 800,
        ShowButtons = new[] { ButtonType.Next, ButtonType.Previous, ButtonType.Close },
    };

    // Cutout animation tours
    private GuideFlowTour? cutoutAnimatedTour, cutoutStaticTour;
    private TourOptions cutoutAnimatedOpts = new()
    {
        AnimateCutout = true,
        ShowButtons = new[] { ButtonType.Next, ButtonType.Previous, ButtonType.Close },
    };
    private TourOptions cutoutStaticOpts = new()
    {
        AnimateCutout = false,
        ShowButtons = new[] { ButtonType.Next, ButtonType.Previous, ButtonType.Close },
    };

    private bool busy;

    private async Task StartTour()
    {
        if (tour != null) await tour.DriveAsync();
    }

    // Animation type handlers
    private async Task ShowFade() { if (fadeTour != null && !busy) { busy = true; await fadeTour.ResetAsync(); await fadeTour.DriveAsync(); } }
    private async Task ShowSlide() { if (slideTour != null && !busy) { busy = true; await slideTour.ResetAsync(); await slideTour.DriveAsync(); } }
    private async Task ShowBounce() { if (bounceTour != null && !busy) { busy = true; await bounceTour.ResetAsync(); await bounceTour.DriveAsync(); } }
    private async Task ShowNone() { if (noneTour != null && !busy) { busy = true; await noneTour.ResetAsync(); await noneTour.DriveAsync(); } }

    // Animate toggle handlers
    private async Task ShowAnimated() { if (animatedTour != null && !busy) { busy = true; await animatedTour.ResetAsync(); await animatedTour.DriveAsync(); } }
    private async Task ShowNotAnimated() { if (notAnimatedTour != null && !busy) { busy = true; await notAnimatedTour.ResetAsync(); await notAnimatedTour.DriveAsync(); } }

    // Duration handlers
    private async Task ShowFast() { if (fastTour != null && !busy) { busy = true; await fastTour.ResetAsync(); await fastTour.DriveAsync(); } }
    private async Task ShowDefaultDuration() { if (defaultDurationTour != null && !busy) { busy = true; await defaultDurationTour.ResetAsync(); await defaultDurationTour.DriveAsync(); } }
    private async Task ShowSlow() { if (slowTour != null && !busy) { busy = true; await slowTour.ResetAsync(); await slowTour.DriveAsync(); } }

    // Cutout animation handlers
    private async Task ShowCutoutAnimated() { if (cutoutAnimatedTour != null && !busy) { busy = true; await cutoutAnimatedTour.ResetAsync(); await cutoutAnimatedTour.DriveAsync(); } }
    private async Task ShowCutoutStatic() { if (cutoutStaticTour != null && !busy) { busy = true; await cutoutStaticTour.ResetAsync(); await cutoutStaticTour.DriveAsync(); } }

    private void OnEnd() { busy = false; StateHasChanged(); }
}
