@page "/docs/animated-tour"
@using GuideFlow.Services
@using GuideFlow.Enums

<PageTitle>Animated Tour - GuideFlow</PageTitle>

<div class="docs-content">
    <h1 id="anim-title">Animated Tour</h1>
    <p class="docs-lead" id="anim-lead">The default tour mode - smoothly animates the overlay and popover as users navigate between steps.</p>

    @* --- Run button --- *@
    <button class="docs-demo__run" @onclick="StartTour" id="anim-run-btn">▶ Show me the example</button>

    @* --- Code Example --- *@
    <h2 id="usage">Usage <a class="docs-anchor" href="#usage">#</a></h2>

    <div id="anim-code">
        <CodeBlock Language="razor" Code="@(@"<GuideFlowTour @ref=""tour"" TourOptions=""options"">
    <GuideFlowStep Element=""#my-header"" Title=""Welcome!"" Order=""0""
                   Side=""Placement.Bottom"" Align=""PopoverAlign.Start"">
        <p>Here is your dashboard header.</p>
    </GuideFlowStep>
    <GuideFlowStep Element=""#my-sidebar"" Title=""Navigation"" Order=""1""
                   Side=""Placement.Right"">
        <p>Use this sidebar to navigate.</p>
    </GuideFlowStep>
    <GuideFlowStep Title=""Happy Coding!"" Order=""2"">
        <p>That's all - go build something great.</p>
    </GuideFlowStep>
</GuideFlowTour>

@code {
    private GuideFlowTour? tour;
    private TourOptions options = new()
    {
        ShowProgress = true,
    };
    private async Task StartTour() { if (tour != null) await tour.DriveAsync(); }
}")" />
    </div>

</div>

@* --- Tour: highlight actual page elements --- *@
<GuideFlowTour @ref="tour" TourOptions="options">
    <GuideFlowStep Element="#anim-code" Title="Animated Tour Example" Order="0"
                   Side="Placement.Left" Align="PopoverAlign.Start">
        <p>Here is the code example showing animated tour. Let's walk you through it.</p>
    </GuideFlowStep>
    <GuideFlowStep Element="#anim-code [data-line='1']" Title="Import the Component" Order="1"
                   Side="Placement.Bottom" Align="PopoverAlign.Start">
        <p>Import the GuideFlow tour and step components into your Blazor page.</p>
    </GuideFlowStep>
    <GuideFlowStep Element="#anim-code [data-line='2']" Title="Importing CSS" Order="2"
                   Side="Placement.Bottom" Align="PopoverAlign.Start">
        <p>Reference the GuideFlow CSS which gives you the default styling for popover and overlay.</p>
    </GuideFlowStep>
    <GuideFlowStep Element="#anim-code [data-line='4']" Title="Create Tour" Order="3"
                   Side="Placement.Left" Align="PopoverAlign.Start">
        <p>Use @("@ref") to capture a reference to the GuideFlowTour component instance.</p>
    </GuideFlowStep>
    <GuideFlowStep Element="#anim-code [data-line='15']" Title="Start Tour" Order="4"
                   Side="Placement.Top" Align="PopoverAlign.Start">
        <p>Call DriveAsync() to start the tour and your tour will be started.</p>
    </GuideFlowStep>
    <GuideFlowStep Element="a[href='/docs/configuration']" Title="More Configuration" Order="5"
                   Side="Placement.Right" Align="PopoverAlign.Start">
        <p>Look at this page for all the configuration options you can pass.</p>
    </GuideFlowStep>
    <GuideFlowStep Title="Happy Coding" Order="6">
        <p>And that is all, go ahead and start adding tours to your applications.</p>
    </GuideFlowStep>
</GuideFlowTour>

@code {
    private GuideFlowTour? tour;

    private TourOptions options = new()
    {
        ShowProgress = true,
    };

    private async Task StartTour()
    {
        if (tour != null) await tour.DriveAsync();
    }
}
