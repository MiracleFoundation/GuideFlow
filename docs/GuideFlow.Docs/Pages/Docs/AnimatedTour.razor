@page "/docs/animated-tour"
@using GuideFlow.Services
@using GuideFlow.Enums

<PageTitle>Animated Tour - GuideFlow</PageTitle>

<div class="docs-content">
    <h1 id="anim-title">Animated Tour</h1>
    <p class="docs-lead" id="anim-lead">The default tour mode - smoothly animates the overlay and popover as users navigate between steps.</p>

    @* --- Run button --- *@
    <button class="docs-demo__run" @onclick="StartTour" id="anim-run-btn">▶ Show me the example</button>

    @* --- Code Example --- *@
    <h2 id="usage">Usage <a class="docs-anchor" href="#usage">#</a></h2>

    <div id="anim-code">
        <CodeBlock Language="razor" Code="@(@"<GuideFlowTour @ref=""tour"" TourOptions=""options"">
    <GuideFlowStep Element=""#anim-title"" Title=""Animated Tour"" Order=""0""
                   Side=""Placement.Bottom"" Align=""PopoverAlign.Start"">
        <p>The default tour mode with smooth animations between steps.</p>
    </GuideFlowStep>
    <GuideFlowStep Element=""#anim-lead"" Title=""Description"" Order=""1""
                   Side=""Placement.Bottom"" Align=""PopoverAlign.Start"">
        <p>This lead text explains what the animated tour does.</p>
    </GuideFlowStep>
    <GuideFlowStep Element=""#anim-run-btn"" Title=""Try It"" Order=""2""
                   Side=""Placement.Right"">
        <p>Click this button to start the tour.</p>
    </GuideFlowStep>
    <GuideFlowStep Element=""#anim-code"" Title=""Code Example"" Order=""3""
                   Side=""Placement.Left"" Align=""PopoverAlign.Start"">
        <p>Here is the code showing how to set up an animated tour.</p>
    </GuideFlowStep>
    <GuideFlowStep Element=""a[href='docs/configuration']"" Title=""More Configuration"" Order=""4""
                   Side=""Placement.Bottom"" Align=""PopoverAlign.Start"">
        <p>Look at this page for all the configuration options you can pass.</p>
    </GuideFlowStep>
    <GuideFlowStep Title=""Happy Coding"" Order=""5"">
        <p>And that is all, go ahead and start adding tours to your applications.</p>
    </GuideFlowStep>
</GuideFlowTour>

@code {
    private GuideFlowTour? tour;
    private TourOptions options = new()
    {
        ShowProgress = true,
    };
    private async Task StartTour() { if (tour != null) await tour.DriveAsync(); }
}")" />
    </div>

    <h2 id="animation-type">Animation Type <a class="docs-anchor" href="#animation-type">#</a></h2>
    <p>Control the popover entrance animation using <code>AnimationType</code>. Four types are available:</p>
    <ul>
        <li><strong>Fade</strong> (default) - Smooth fade in with slight upward movement</li>
        <li><strong>Slide</strong> - Slides in from the direction of the placement</li>
        <li><strong>Bounce</strong> - Bouncy entrance effect</li>
        <li><strong>None</strong> - Instant appearance, no animation</li>
    </ul>

    <div class="popover-demo">
        <div class="popover-demo__target" id="anim-type-target">
            <span>Target Element</span>
        </div>
        <div class="popover-demo__buttons" style="margin-top:1.5rem; grid-template-columns: repeat(4, 1fr);">
            <button class="docs-btn" @onclick="ShowFade">Fade (default)</button>
            <button class="docs-btn" @onclick="ShowSlide">Slide</button>
            <button class="docs-btn" @onclick="ShowBounce">Bounce</button>
            <button class="docs-btn" @onclick="ShowNone">None</button>
        </div>
    </div>

    <h3>Code</h3>
    <div id="anim-type-code">
        <CodeBlock Language="razor" Code="@(@"private TourOptions options = new()
{
    AnimationType = AnimationType.Slide,   // Fade, Slide, Bounce, None
};")" />
    </div>

    <h2 id="animate-toggle">Enable / Disable Animation <a class="docs-anchor" href="#animate-toggle">#</a></h2>
    <p>Set <code>Animate = false</code> to disable all animations globally. The tour will switch steps instantly with no transitions.</p>

    <div class="popover-demo">
        <div class="popover-demo__target" id="anim-toggle-target">
            <span>Target Element</span>
        </div>
        <div class="popover-demo__buttons" style="margin-top:1.5rem; grid-template-columns: repeat(2, 1fr);">
            <button class="docs-btn" @onclick="ShowAnimated">Animated (default)</button>
            <button class="docs-btn" @onclick="ShowNotAnimated">No Animation</button>
        </div>
    </div>

    <h3>Code</h3>
    <div id="anim-toggle-code">
        <CodeBlock Language="razor" Code="@(@"private TourOptions options = new()
{
    Animate = false,   // disables all animations
};")" />
    </div>

    <h2 id="animation-duration">Animation Duration <a class="docs-anchor" href="#animation-duration">#</a></h2>
    <p>Use <code>AnimationDuration</code> to control how long the animation takes in milliseconds. Default is 300ms.</p>

    <div class="popover-demo">
        <div class="popover-demo__target" id="anim-duration-target">
            <span>Target Element</span>
        </div>
        <div class="popover-demo__buttons" style="margin-top:1.5rem; grid-template-columns: repeat(3, 1fr);">
            <button class="docs-btn" @onclick="ShowFast">Fast (150ms)</button>
            <button class="docs-btn" @onclick="ShowDefaultDuration">Default (300ms)</button>
            <button class="docs-btn" @onclick="ShowSlow">Slow (800ms)</button>
        </div>
    </div>

    <h3>Code</h3>
    <div id="anim-duration-code">
        <CodeBlock Language="razor" Code="@(@"private TourOptions options = new()
{
    AnimationDuration = 600,   // 600ms transition
};")" />
    </div>

    <h2 id="cutout-animation">Cutout Animation <a class="docs-anchor" href="#cutout-animation">#</a></h2>
    <p>When <code>AnimateCutout = true</code> (default), the overlay cutout smoothly moves between elements as you navigate steps. Set to <code>false</code> to make the cutout jump instantly.</p>

    <div class="popover-demo">
        <div class="popover-demo__target" id="anim-cutout-target">
            <span>Target Element</span>
        </div>
        <div class="popover-demo__buttons" style="margin-top:1.5rem; grid-template-columns: repeat(2, 1fr);">
            <button class="docs-btn" @onclick="ShowCutoutAnimated">Animated Cutout</button>
            <button class="docs-btn" @onclick="ShowCutoutStatic">Static Cutout</button>
        </div>
    </div>

    <h3>Code</h3>
    <div id="anim-cutout-code">
        <CodeBlock Language="razor" Code="@(@"// Animated cutout (default) - smooth transition between elements
private TourOptions animatedCutout = new()
{
    AnimateCutout = true,
};

// Static cutout - instant jump
private TourOptions staticCutout = new()
{
    AnimateCutout = false,
};")" />
    </div>

</div>

@* --- Default animated tour (multi-step) --- *@
<GuideFlowTour @ref="tour" TourOptions="defaultOpts" OnComplete="OnEnd" OnCancel="OnEnd">
    <GuideFlowStep Element="#anim-title" Title="Animated Tour" Order="0"
                   Side="Placement.Bottom" Align="PopoverAlign.Start">
        <p>The default tour mode with smooth animations between steps.</p>
    </GuideFlowStep>
    <GuideFlowStep Element="#anim-lead" Title="Description" Order="1"
                   Side="Placement.Bottom" Align="PopoverAlign.Start">
        <p>This lead text explains what the animated tour does.</p>
    </GuideFlowStep>
    <GuideFlowStep Element="#anim-run-btn" Title="Try It" Order="2"
                   Side="Placement.Right">
        <p>Click this button to start the tour.</p>
    </GuideFlowStep>
    <GuideFlowStep Element="#anim-code" Title="Code Example" Order="3"
                   Side="Placement.Left" Align="PopoverAlign.Start">
        <p>Here is the code showing how to set up an animated tour.</p>
    </GuideFlowStep>
    <GuideFlowStep Element="a[href='docs/configuration']" Title="More Configuration" Order="4"
                   Side="Placement.Bottom" Align="PopoverAlign.Start">
        <p>Look at this page for all the configuration options you can pass.</p>
    </GuideFlowStep>
    <GuideFlowStep Title="Happy Coding" Order="5">
        <p>And that is all, go ahead and start adding tours to your applications.</p>
    </GuideFlowStep>
</GuideFlowTour>

