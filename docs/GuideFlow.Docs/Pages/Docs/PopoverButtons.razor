@page "/docs/popover-buttons"
@using GuideFlow.Services
@using GuideFlow.Enums

<PageTitle>Popover Buttons - GuideFlow</PageTitle>

<div class="docs-content">
    <h1 id="popover-buttons-title">Popover Buttons</h1>
    <p class="docs-lead" id="popover-buttons-lead">Show, hide, or relabel the Next, Previous, Skip, and Done buttons in the popover. Add custom button classes, control visibility per-step, or use the built-in progress counter as a button label.</p>

    <button class="docs-demo__run" @onclick="StartTour" id="popover-buttons-run-btn">▶ Show me the example</button>

    <h2 id="usage">Usage <a class="docs-anchor" href="#usage">#</a></h2>

    <div id="popover-buttons-code">
        <CodeBlock Language="razor" Code="@(@"<GuideFlowTour @ref=""tour"" TourOptions=""options"">
    <GuideFlowStep Element=""#popover-buttons-title"" Title=""Step 1"" Order=""0""
                   Side=""Placement.Bottom"" Align=""PopoverAlign.Start"">
        <p>Custom button text example.</p>
    </GuideFlowStep>
    <GuideFlowStep Element=""#popover-buttons-code"" Title=""Step 2"" Order=""1""
                   Side=""Placement.Top"">
        <p>Skipping the skip button.</p>
    </GuideFlowStep>
    <GuideFlowStep Element=""#popover-buttons-run-btn"" Title=""Step 3"" Order=""2""
                   Side=""Placement.Right"">
        <p>Final step with custom Done text.</p>
    </GuideFlowStep>
</GuideFlowTour>

@code {
    private GuideFlowTour? tour;
    private TourOptions options = new()
    {
        NextBtnText = ""Continue"",
        PrevBtnText = ""Back"",
        DoneBtnText = ""Finish"",
        SkipBtnText = ""Exit"",
        ShowButtons = true,
    };
    private async Task StartTour() { if (tour != null) await tour.DriveAsync(); }
}")" />
    </div>

</div>

<GuideFlowTour @ref="tour" TourOptions="options">
    <GuideFlowStep Element="#popover-buttons-title" Title="Step 1" Order="0"
                   Side="Placement.Bottom" Align="PopoverAlign.Start">
        <p>Custom button text example.</p>
    </GuideFlowStep>
    <GuideFlowStep Element="#popover-buttons-code" Title="Step 2" Order="1"
                   Side="Placement.Top">
        <p>Skipping the skip button.</p>
    </GuideFlowStep>
    <GuideFlowStep Element="#popover-buttons-run-btn" Title="Step 3" Order="2"
                   Side="Placement.Right">
        <p>Final step with custom Done text.</p>
    </GuideFlowStep>
</GuideFlowTour>

@code {
    private GuideFlowTour? tour;

    private TourOptions options = new()
    {
        NextBtnText = "Continue",
        PrevBtnText = "Back",
        DoneBtnText = "Finish",
        SkipBtnText = "Exit",
    };

    private async Task StartTour()
    {
        if (tour != null) await tour.DriveAsync();
    }
}
