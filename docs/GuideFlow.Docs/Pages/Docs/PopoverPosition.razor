@page "/docs/popover-position"
@using GuideFlow.Services
@using GuideFlow.Enums

<PageTitle>Popover Position - GuideFlow</PageTitle>

<div class="docs-content">
    <h1 id="popover-position-title">Popover Position</h1>
    <p class="docs-lead" id="popover-position-lead">You can control the popover position using the <code>Side</code> and <code>Align</code> options. The <code>Side</code> option controls the side of the element where the popover will be shown and the <code>Align</code> option controls the alignment of the popover with the element.</p>

    <div class="docs-callout docs-callout--info">
        <strong>Note:</strong> Popover is intelligent enough to adjust itself to fit in the viewport. So, if you set <code>Side</code> to <code>Left</code> and <code>Align</code> to <code>Start</code>, but the popover doesn't fit in the viewport, it will automatically adjust itself to fit in the viewport. Consider highlighting and scrolling the browser to the element below to see this in action.
    </div>

    <h2 id="usage">Usage <a class="docs-anchor" href="#usage">#</a></h2>

    <div id="popover-position-code">
        <CodeBlock Language="razor" Code="@(@"<GuideFlowStep Element=""#my-element"" Title=""Popover Title""
               Side=""Placement.Left"" Align=""PopoverAlign.Start"">
    <p>Popover content here.</p>
</GuideFlowStep>

@code {
    // Side: Top, Bottom, Left, Right
    // Align: Start, Center, End
}")" />
    </div>

    <h2 id="demo">Demo <a class="docs-anchor" href="#demo">#</a></h2>
    <p>Use the buttons below to show the popover at different positions.</p>

    <div class="popover-demo">
        <div class="popover-demo__target" id="popover-demo-target">
            <span>Target Element</span>
        </div>

        <div class="popover-demo__buttons">
            <div class="popover-demo__group">
                <h4>Left</h4>
                <button class="docs-btn" @onclick="() => ShowAsync(Placement.Left, PopoverAlign.Start)">Start</button>
                <button class="docs-btn" @onclick="() => ShowAsync(Placement.Left, PopoverAlign.Center)">Center</button>
                <button class="docs-btn" @onclick="() => ShowAsync(Placement.Left, PopoverAlign.End)">End</button>
            </div>
            <div class="popover-demo__group">
                <h4>Top</h4>
                <button class="docs-btn" @onclick="() => ShowAsync(Placement.Top, PopoverAlign.Start)">Start</button>
                <button class="docs-btn" @onclick="() => ShowAsync(Placement.Top, PopoverAlign.Center)">Center</button>
                <button class="docs-btn" @onclick="() => ShowAsync(Placement.Top, PopoverAlign.End)">End</button>
            </div>
            <div class="popover-demo__group">
                <h4>Right</h4>
                <button class="docs-btn" @onclick="() => ShowAsync(Placement.Right, PopoverAlign.Start)">Start</button>
                <button class="docs-btn" @onclick="() => ShowAsync(Placement.Right, PopoverAlign.Center)">Center</button>
                <button class="docs-btn" @onclick="() => ShowAsync(Placement.Right, PopoverAlign.End)">End</button>
            </div>
            <div class="popover-demo__group">
                <h4>Bottom</h4>
                <button class="docs-btn" @onclick="() => ShowAsync(Placement.Bottom, PopoverAlign.Start)">Start</button>
                <button class="docs-btn" @onclick="() => ShowAsync(Placement.Bottom, PopoverAlign.Center)">Center</button>
                <button class="docs-btn" @onclick="() => ShowAsync(Placement.Bottom, PopoverAlign.End)">End</button>
            </div>
        </div>
    </div>

</div>

<GuideFlowTour @ref="tour" TourOptions="options" />

@code {
    private GuideFlowTour? tour;

    private TourOptions options = new()
    {
        ShowProgress = false,
    };

    private async Task ShowAsync(Placement side, PopoverAlign align)
    {
        if (tour == null) return;
        await tour.HighlightAsync("#popover-demo-target", "Popover Title",
            $"Popover positioned at {side.ToString().ToLower()} - {align.ToString().ToLower()}.",
            side, align);
    }
}
