@inherits LayoutComponentBase

<div class="landing">
    <div class="landing-topbar">
        <a href="https://github.com/MiracleFoundation/GuideFlow" target="_blank" class="landing-github-btn" aria-label="View on GitHub">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/></svg>
            <span class="landing-github-stars" id="github-stars">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M12 .587l3.668 7.431 8.2 1.191-5.934 5.782 1.4 8.168L12 19.347l-7.334 3.812 1.4-8.168L.132 9.209l8.2-1.191z"/></svg>
                <span id="github-stars-count">---</span>
            </span>
        </a>
        <button class="docs-theme-toggle" onclick="toggleDocsTheme()" aria-label="Toggle theme">
            <span class="docs-theme-toggle__light">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M21 12.79A9 9 0 1111.21 3a7 7 0 009.79 9.79z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </span>
            <span class="docs-theme-toggle__dark">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="5" stroke="currentColor" stroke-width="1.5"/><path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
            </span>
        </button>
    </div>

    @Body

    <footer class="landing-footer">
        <div class="landing-footer__inner">
            <span>GuideFlow &copy; 2026 &bull; MIT License</span>
            <a href="https://github.com/MiracleFoundation/GuideFlow" target="_blank">GitHub</a>
        </div>
    </footer>
</div>
